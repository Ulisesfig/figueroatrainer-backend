# Configuración del servidor
NODE_ENV=development
PORT=3000

# JWT Secret Key - Genera una clave única y segura
JWT_SECRET=your_super_secret_jwt_key_here

# PostgreSQL Database URL
# Para desarrollo local:
DATABASE_URL=postgresql://usuario:password@localhost:5432/figueroatrainer

# Para Railway, Railway automáticamente inyectará DATABASE_URL
# Solo necesitas configurarlo en las variables de entorno de Railway

# Configuración de Cookies
COOKIE_SECURE=false
# En producción, cambia a true

# CORS Origins permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,https://figueroatrainer.netlify.app,https://figueroatrainer.com,https://www.figueroatrainer.com

# Pagos (opcional): activar monto de prueba para validar cobros en produccion
# false = usar precios reales del plan
# true = forzar todos los planes pagos al valor de PAYMENT_TEST_AMOUNT_ARS
PAYMENT_FORCE_TEST_AMOUNT=false
PAYMENT_TEST_AMOUNT_ARS=100

# Configuración SMTP2GO para envío de emails
# Datos típicos de SMTP2GO:
# - Host: mail.smtp2go.com
# - Puerto: 587 o 2525
# - Usuario: tu usuario SMTP2GO
# - Password: tu password/API key SMTP2GO
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-usuario-smtp2go
SMTP_PASS=tu-password-smtp2go
SMTP2GO_API_KEY=api-tuapikeysmtp2go
FROM_EMAIL=tu-remitente-verificado@tu-dominio.com
ADMIN_EMAIL=admin@figueroatrainer.com
